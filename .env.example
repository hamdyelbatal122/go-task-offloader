# ──────────────────────────────────────────────────────────────────────────────
#  go-task-offloader — Environment Variables Reference
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Redis ─────────────────────────────────────────────────────────────────────
# Address of the Redis server (host:port).
# Must point to the same Redis instance your Laravel app uses.
REDIS_ADDR=localhost:6379

# Redis AUTH password. Leave empty if your Redis has no password.
REDIS_PASSWORD=

# Redis database index (0–15). Matches Laravel's redis.default.database.
REDIS_DB=0

# ── Queue ─────────────────────────────────────────────────────────────────────
# The Redis list name the Go worker reads from.
# Must match the queue name used in your Laravel ->onQueue(...) calls.
# Laravel stores jobs at "queues:{QUEUE_NAME}".
QUEUE_NAME=default

# Dead Letter Queue name. Failed jobs (after MAX_RETRIES) are pushed here.
# Inspect with: redis-cli LRANGE queues:failed 0 -1
# Replay with:  php artisan queue:retry all
DLQ_NAME=failed

# ── Worker Pool ───────────────────────────────────────────────────────────────
# Number of goroutines that process jobs concurrently.
# Recommended starting point: 2 × number of CPU cores.
WORKER_COUNT=10

# Maximum number of processing attempts before a job is permanently failed.
# Set to 1 to disable retries.
MAX_RETRIES=3

# ── Health Server ─────────────────────────────────────────────────────────────
# HTTP port for the liveness probe and metrics endpoint.
# GET /health  → {"status":"ok"}
# GET /metrics → runtime stats (goroutines, RAM, GC, uptime)
HEALTH_PORT=8080
